---
interface Props {
	activePath?: string;
}

const { activePath = Astro.url.pathname } = Astro.props as Props;

const baseLinkClass =
	'block py-2 px-3 rounded md:p-0 md:border-0 md:hover:bg-transparent md:hover:text-blue-700 dark:text-white md:dark:hover:text-blue-500 hover:bg-gray-100 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent';

const activeLinkClass =
	'text-white bg-blue-700 md:bg-transparent md:text-blue-700 dark:text-white md:dark:text-blue-500';

const idleLinkClass = 'text-gray-900';

const isActive = (path: string) => activePath.toLowerCase() === path.toLowerCase();
---

<nav class="bg-white border-gray-200 dark:bg-gray-900" data-app-header>
	<div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
		<a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
			<img src="#" class="h-8" alt="Logo" />
			<span class="self-center text-2xl font-serif whitespace-nowrap dark:text-white">Portfolio</span>
		</a>

		<button
			data-collapse-toggle="navbar-default"
			type="button"
			class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600"
			aria-controls="navbar-default"
			aria-expanded="false"
		>
			<span class="sr-only">Open main menu</span>
			<svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
				<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15" />
			</svg>
		</button>

		<div class="hidden w-full md:block md:w-auto" id="navbar-default">
			<ul class="font-semibold flex flex-col p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-white dark:bg-gray-800 md:dark:bg-gray-900 dark:border-gray-700">
				<li>
					<a href="/" class={`${baseLinkClass} ${isActive('/') ? activeLinkClass : idleLinkClass}`} aria-current={isActive('/') ? 'page' : undefined}>Home</a>
				</li>
				<li>
					<a href="#" class={`${baseLinkClass} ${idleLinkClass}`}>About</a>
				</li>
				<li>
					<a href="#" class={`${baseLinkClass} ${idleLinkClass}`}>Services</a>
				</li>
				<li>
					<a href="/Project" class={`${baseLinkClass} ${isActive('/Project') ? activeLinkClass : idleLinkClass}`}>Project</a>
				</li>
				<li>
					<a href="contact" class={`${baseLinkClass} ${idleLinkClass}`}>Contact</a>
				</li>
				<li>
					<a href="/Tech" class={`${baseLinkClass} ${isActive('/Tech') ? activeLinkClass : idleLinkClass}`}>Tech Stack</a>
				</li>
				<li>
					<a href="/work" class={`${baseLinkClass} ${isActive('/work') ? activeLinkClass : idleLinkClass}`}>Work</a>
				</li>
			</ul>
		</div>

		<div class="w-full mt-4 md:mt-0 md:w-auto md:ml-6">
			<div class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 dark:border-gray-700 dark:bg-gray-800">
				<img id="profileImg" class="h-12 w-12 rounded-full object-cover" src="https://randomuser.me/api/portraits/women/44.jpg" alt="Profile" />
				<div class="min-w-0">
					<h2 class="truncate text-sm font-narrow text-gray-900 dark:text-white">Dela Cruz, John Clarence A.</h2>
					<p class="truncate text-xs text-gray-500 dark:text-gray-300">Aspiring Web Developer & Tech Support</p>
					<div class="mt-1 flex items-center">
						<span class="h-2 w-2 rounded-full bg-green-500"></span>
						<span class="ml-2 text-xs text-green-600 dark:text-green-400">Online</span>
					</div>
				</div>
				<label for="profileUpload" class="cursor-pointer text-xs text-blue-600 hover:underline dark:text-blue-400">Photo</label>
				<input id="profileUpload" type="file" accept="image/*" class="hidden" />
			</div>
		</div>
	</div>
</nav>

<script>
	const initHeader = () => {
		const header = document.querySelector('[data-app-header]');
		if (!header) return;

		const menuBtn = header.querySelector('[data-collapse-toggle="navbar-default"]');
		const menu = header.querySelector('#navbar-default');
		if (menuBtn && menu) {
			menuBtn.addEventListener('click', () => {
				menu.classList.toggle('hidden');
			});
		}

		const profileImg = header.querySelector('#profileImg') as HTMLImageElement | null;
		const profileUpload = header.querySelector('#profileUpload') as HTMLInputElement | null;
		const profileKey = 'profileImg';
		const maxDimension = 512;
		const jpegQuality = 0.85;

		const loadProfileImg = () => {
			try {
				return localStorage.getItem(profileKey);
			} catch {
				return null;
			}
		};

		const saveProfileImg = (dataUrl: string) => {
			try {
				localStorage.setItem(profileKey, dataUrl);
			} catch (err) {
				console.warn('Profile image could not be saved to localStorage.', err);
			}
		};

		const resizeImage = (dataUrl: string, callback: (compressed: string) => void) => {
			const img = new Image();
			img.onload = () => {
				const scale = Math.min(1, maxDimension / Math.max(img.width, img.height));
				const canvas = document.createElement('canvas');
				canvas.width = Math.round(img.width * scale);
				canvas.height = Math.round(img.height * scale);
				const ctx = canvas.getContext('2d');
				if (!ctx) return;
				ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
				const compressed = canvas.toDataURL('image/jpeg', jpegQuality);
				callback(compressed);
			};
			img.src = dataUrl;
		};

		if (profileImg && profileUpload) {
			const savedProfileImg = loadProfileImg();
			if (savedProfileImg) {
				profileImg.src = savedProfileImg;
			}

			profileUpload.addEventListener('change', (e) => {
				const input = e.target;
				if (input && input instanceof HTMLInputElement && input.files && input.files[0]) {
					const file = input.files[0];
					const reader = new FileReader();
					reader.onload = function (ev: ProgressEvent<FileReader>) {
						if (profileImg && ev.target && typeof ev.target.result === 'string') {
							resizeImage(ev.target.result, (compressed) => {
								profileImg.src = compressed;
								saveProfileImg(compressed);
							});
						}
					};
					reader.readAsDataURL(file);
				}
			});
		}
	};

	document.addEventListener('DOMContentLoaded', initHeader);
</script>
