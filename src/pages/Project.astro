---
import '../styles/global.css';
import Header from '../components/Header.astro';
import smis from '../assets/smis.png';
import Game from '../assets/Game.png';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio</title>
  </head>
  <body>
<Header activePath="/Project" />

<!-- Carousel -->

<div
  id="carouselExampleCaptions"
  class="relative"
  data-carousel>
  <!--Carousel indicators-->
  <div
    class="absolute bottom-0 left-0 right-0 z-[2] mx-[15%] mb-4 flex list-none justify-center p-0"
    data-carousel-indicators>
    <button
      type="button"
      data-slide-to="0"
      data-active
      class="mx-[3px] box-content h-[3px] w-[30px] flex-initial cursor-pointer border-0 border-y-[10px] border-solid border-transparent bg-white bg-clip-padding p-0 -indent-[999px] opacity-50 transition-opacity duration-[600ms] ease-[cubic-bezier(0.25,0.1,0.25,1.0)] motion-reduce:transition-none"
      aria-current="true"
      aria-label="Slide 1"></button>
    <button
      type="button"
      data-slide-to="1"
      class="mx-[3px] box-content h-[3px] w-[30px] flex-initial cursor-pointer border-0 border-y-[10px] border-solid border-transparent bg-white bg-clip-padding p-0 -indent-[999px] opacity-50 transition-opacity duration-[600ms] ease-[cubic-bezier(0.25,0.1,0.25,1.0)] motion-reduce:transition-none"
      aria-label="Slide 2"></button>
    <button
      type="button"
      data-slide-to="2"
      class="mx-[3px] box-content h-[3px] w-[30px] flex-initial cursor-pointer border-0 border-y-[10px] border-solid border-transparent bg-white bg-clip-padding p-0 -indent-[999px] opacity-50 transition-opacity duration-[600ms] ease-[cubic-bezier(0.25,0.1,0.25,1.0)] motion-reduce:transition-none"
      aria-label="Slide 3"></button>
  </div>

  <!--Carousel items-->
  <div
    class="relative w-full h-[70vh] overflow-hidden">
    <!--First item-->
    <div
      class="absolute inset-0 w-full opacity-100 transition-opacity duration-[600ms] ease-in-out"
      data-carousel-slide
      data-active>
      <img
        src={smis.src}
        class="block h-full w-full object-cover"
        alt="..." />
      <div
        class="absolute inset-x-[6%] bottom-6 block md:inset-x-[15%] md:bottom-5">
        <div class="mx-auto max-w-xl rounded-md bg-black/45 px-3 py-2 text-center text-white shadow-lg backdrop-blur-sm md:px-4 md:py-3">
          <h5 class="text-lg font-semibold tracking-wide md:text-2xl">Supply Management Information System (SMIS)</h5>
          <p class="mt-1 text-xs text-white/90 md:text-sm">
            Our Capstone Project, A Web Based Application
          </p>
        </div>
      </div>
    </div>
    <!--Second item-->
    <div
      class="absolute inset-0 w-full opacity-0 transition-opacity duration-[600ms] ease-in-out"
      data-carousel-slide>
      <img
        src={Game.src}
        class="block h-full w-full object-cover"
        alt="..." />
      <div
        class="absolute inset-x-[6%] bottom-6 block md:inset-x-[15%] md:bottom-5">
        <div class="mx-auto max-w-xl rounded-md bg-black/45 px-3 py-2 text-center text-white shadow-lg backdrop-blur-sm md:px-4 md:py-3">
          <h5 class="text-lg font-semibold tracking-wide md:text-2xl">Makabre</h5>
          <p class="mt-1 text-xs text-white/90 md:text-sm">
            A Fps Horror Game created in Unity by our group Malevolent Kitchen
          </p>
        </div>
      </div>
    </div>
    <!--Third item-->
    <div
      class="absolute inset-0 w-full opacity-0 transition-opacity duration-[600ms] ease-in-out"
      data-carousel-slide>
      <img
        src="https://tecdn.b-cdn.net/img/Photos/Slides/img%20(23).jpg"
        class="block h-full w-full object-cover"
        alt="..." />
      <div
        class="absolute inset-x-[6%] bottom-6 block md:inset-x-[15%] md:bottom-5">
        <div class="mx-auto max-w-xl rounded-md bg-black/45 px-3 py-2 text-center text-white shadow-lg backdrop-blur-sm md:px-4 md:py-3">
          <h5 class="text-lg font-semibold tracking-wide md:text-2xl">Third slide label</h5>
          <p class="mt-1 text-xs text-white/90 md:text-sm">
            Some representative placeholder content for the third slide.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!--Carousel controls - prev item-->
  <button
    class="absolute bottom-0 left-0 top-0 z-[1] flex w-[15%] items-center justify-center border-0 bg-none p-0 text-center text-white opacity-50 transition-opacity duration-150 ease-[cubic-bezier(0.25,0.1,0.25,1.0)] hover:text-white hover:no-underline hover:opacity-90 hover:outline-none focus:text-white focus:no-underline focus:opacity-90 focus:outline-none motion-reduce:transition-none"
    type="button"
    data-slide="prev">
    <span class="inline-block h-8 w-8">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="h-6 w-6">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    </span>
    <span
      class="!absolute !-m-px !h-px !w-px !overflow-hidden !whitespace-nowrap !border-0 !p-0 ![clip:rect(0,0,0,0)]"
      >Previous</span
    >
  </button>
  <!--Carousel controls - next item-->
  <button
    class="absolute bottom-0 right-0 top-0 z-[1] flex w-[15%] items-center justify-center border-0 bg-none p-0 text-center text-white opacity-50 transition-opacity duration-150 ease-[cubic-bezier(0.25,0.1,0.25,1.0)] hover:text-white hover:no-underline hover:opacity-90 hover:outline-none focus:text-white focus:no-underline focus:opacity-90 focus:outline-none motion-reduce:transition-none"
    type="button"
    data-slide="next">
    <span class="inline-block h-8 w-8">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="h-6 w-6">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </span>
    <span
      class="!absolute !-m-px !h-px !w-px !overflow-hidden !whitespace-nowrap !border-0 !p-0 ![clip:rect(0,0,0,0)]"
      >Next</span
    >
  </button>
</div>

<section class="mx-auto mt-8 max-w-6xl px-4 pb-10 sm:px-6 lg:px-8" aria-live="polite">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Tech Stack Used</p>
    <h2 id="stackTitle" class="mt-2 text-2xl font-bold text-slate-900">Supply Management Information System (SMIS)</h2>
    <p id="stackSummary" class="mt-2 text-sm text-slate-600">Core technologies used to build the web-based capstone platform.</p>
    <div id="stackTags" class="mt-4 flex flex-wrap gap-2"></div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slides = Array.from(document.querySelectorAll('[data-carousel-slide]'));
    const indicators = Array.from(
      document.querySelectorAll('[data-carousel-indicators] [data-slide-to]')
    );
    const stackTitle = document.getElementById('stackTitle');
    const stackSummary = document.getElementById('stackSummary');
    const stackTags = document.getElementById('stackTags');

    const techStacks = [
      {
        title: 'Supply Management Information System (SMIS)',
        summary: 'Core technologies used to build the web-based capstone platform.',
        tags: ['HTML', 'CSS', 'JavaScript', 'PHP', 'Laravel', 'MySQL', 'Bootstrap']
      },
      {
        title: 'Makabre (FPS Horror Game)',
        summary: 'Technologies and tools used for the game experience and pipeline.',
        tags: ['Unity(For Animation)', 'C#', 'Blender', 'Photoshop', 'FMOD', 'Git']
      },
      {
        title: 'Upcoming Project',
        summary: 'Placeholder stack while this project details are being finalized.',
        tags: ['Astro', 'Tailwind CSS', 'TypeScript', 'Node.js']
      }
    ];

    let activeIndex = slides.findIndex((slide) => slide.hasAttribute('data-active'));
    if (activeIndex === -1) activeIndex = 0;

    const updateStackDetails = (index: number) => {
      const details = techStacks[index];
      if (!details || !stackTitle || !stackSummary || !stackTags) return;

      stackTitle.textContent = details.title;
      stackSummary.textContent = details.summary;
      stackTags.innerHTML = '';

      details.tags.forEach((tag) => {
        const chip = document.createElement('span');
        chip.className = 'inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700';
        chip.textContent = tag;
        stackTags.appendChild(chip);
      });
    };

    const setActive = (index: number) => {
      slides.forEach((slide, i) => {
        if (i === index) {
          slide.setAttribute('data-active', '');
          slide.classList.add('opacity-100');
          slide.classList.remove('opacity-0');
        } else {
          slide.removeAttribute('data-active');
          slide.classList.add('opacity-0');
          slide.classList.remove('opacity-100');
        }
      });

      indicators.forEach((btn, i) => {
        if (i === index) {
          btn.setAttribute('data-active', '');
          btn.classList.add('opacity-100');
          btn.classList.remove('opacity-50');
        } else {
          btn.removeAttribute('data-active');
          btn.classList.add('opacity-50');
          btn.classList.remove('opacity-100');
        }
      });

      updateStackDetails(index);
      activeIndex = index;
    };

    const next = () => setActive((activeIndex + 1) % slides.length);
    const prev = () => setActive((activeIndex - 1 + slides.length) % slides.length);

    document.querySelectorAll('[data-slide="next"]').forEach((btn) => {
      btn.addEventListener('click', next);
    });
    document.querySelectorAll('[data-slide="prev"]').forEach((btn) => {
      btn.addEventListener('click', prev);
    });
    indicators.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = Number(btn.getAttribute('data-slide-to'));
        if (!Number.isNaN(target)) setActive(target);
      });
    });

    setActive(activeIndex);
  });
</script>

  </body>
</html>