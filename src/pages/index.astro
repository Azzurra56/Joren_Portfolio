---
import '../styles/global.css';
import Header from '../components/Header.astro';
import smis from '../assets/smis.png';
import Game from '../assets/Game.png';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio</title>
  </head>
  <body>
<Header activePath="/" />

  <div class="container mx-auto px-5 py-2 lg:px-32 lg:pt-12">
    <h2 class="text 2x-l font-italic mb-4 text-left"> Projects</h2>
    <div class="-m-1 flex flex-wrap md:-m-2">
      <div class="flex w-1/3 flex-wrap">
        <div class="w-full p-1 md:p-2">
          <div class="relative aspect-[16/9] w-full">
            <img
              alt="gallery"
              class="block w-full h-full rounded-lg object-cover object-center cursor-pointer hover:shadow-lg"
              src={smis.src}
              onclick="openModal(this.src)"
            />
            <span class="absolute bottom-1 left-1 bg-black bg-opacity-30 text-white px-2 py-1 rounded text-xs sm:text-sm md:text-base lg:text-lg pointer-events-none max-w-[90%] sm:max-w-[80%] md:max-w-[70%] break-words leading-tight">
              (SMIS) Project Manager
            </span>
          </div>
        </div>
      </div>
      <div class="flex w-1/3 flex-wrap">
        <div class="w-full p-1 md:p-2">
          <div class="relative aspect-[16/9] w-full">
            <img
              alt="gallery"
              class="block w-full h-full rounded-lg object-cover object-center cursor-pointer hover:shadow-lg"
              src={Game.src}
              onclick="openModal(this.src)"
            />
            <span class="absolute bottom-1 left-1 bg-opacity-60 text-white px-2 py-1 rounded text-xs sm:text-sm md:text-base lg:text-lg pointer-events-none max-w-[90%] sm:max-w-[80%] md:max-w-[70%] break-words leading-tight">
              Makabre (Game Animator)
            </span>
          </div>
        </div>
      </div>
      <div class="flex w-1/3 flex-wrap">
        <div class="w-full p-1 md:p-2">
            <div class="relative aspect-[16/9] w-full">
          <img
            alt="gallery"
            class="block h-full w-full rounded-lg object-cover object-center cursor-pointer"
            src="https://tecdn.b-cdn.net/img/Photos/Horizontal/Nature/4-col/img%20(75).webp"
            onclick="openModal(this.src)"
          />
        </div>
      </div>
      </div>
      <div class="flex w-1/3 flex-wrap">
        <div class="w-full p-1 md:p-2">
          <img
            alt="gallery"
            class="block h-full w-full rounded-lg object-cover object-center cursor-pointer"
            src="https://tecdn.b-cdn.net/img/Photos/Horizontal/Nature/4-col/img%20(70).webp"
            onclick="openModal(this.src)"
          />
        </div>
      </div>
      <div class="flex w-1/3 flex-wrap">
        <div class="w-full p-1 md:p-2">
          <img
            alt="gallery"
            class="block h-full w-full rounded-lg object-cover object-center cursor-pointer"
            src="https://tecdn.b-cdn.net/img/Photos/Horizontal/Nature/4-col/img%20(76).webp"
            onclick="openModal(this.src)"
          />
        </div>
      </div>
      <div class="flex w-1/3 flex-wrap">
        <div class="w-full p-1 md:p-2">
          <img
            alt="gallery"
            class="block h-full w-full rounded-lg object-cover object-center cursor-pointer"
            src="https://tecdn.b-cdn.net/img/Photos/Horizontal/Nature/4-col/img%20(72).webp"
            onclick="openModal(this.src)"
          />
        </div>
      </div>
    </div>
  </div>

<!-- Modal -->
<div id="imageModal" class="fixed inset-0 z-50 hidden bg-black bg-opacity-70 flex items-center justify-center">
  <span class="absolute top-4 right-8 text-white text-4xl cursor-pointer" id="closeModal">&times;</span>
  <div class="flex flex-col items-center">
    <img id="modalImg" class="max-h-[80vh] max-w-[90vw] rounded-lg shadow-lg" src="" alt="modal" />
    <div id="modalCaption" class="mt-4 text-white text-lg text-center"></div>
  </div>
</div>

<script>
  const openModal = (src: string) => {
    const modal = document.getElementById('imageModal');
    const modalImg = document.getElementById('modalImg') as HTMLImageElement | null;
    if (modalImg) modalImg.src = src;
    if (modal) modal.classList.remove('hidden');
  };
  (window as any).openModal = openModal;

  document.addEventListener('DOMContentLoaded', () => {
    // Modal close logic
    const modal = document.getElementById('imageModal');
    const closeBtn = document.getElementById('closeModal');
    if (closeBtn && modal) {
      closeBtn.onclick = () => {
        modal.classList.add('hidden');
      };
      modal.onclick = (e) => {
        if (e.target === modal) modal.classList.add('hidden');
      };
    }
  });
</script>

  </body>
</html>