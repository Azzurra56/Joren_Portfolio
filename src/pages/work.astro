---
import '../styles/global.css';
import Header from '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Work</title>
  </head>
  <body>
    <Header activePath="/work" />

    <main class="mx-auto max-w-5xl px-6 py-14">
      <h1 class="text-3xl font-bold text-slate-900 md:text-4xl">Work Experience</h1>
      <p class="mt-4 text-slate-600">
        This section is ready for your work timeline, internships, and key professional achievements.
      </p>
    </main>
  </body>
</html>
