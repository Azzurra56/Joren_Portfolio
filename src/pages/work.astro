---
import '../styles/global.css';
import '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio</title>
  </head>
  <body>



<nav class="bg-white border-gray-200 dark:bg-gray-900">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
    <a href="#" class="flex items-center space-x-3 rtl:space-x-reverse">
        <img src="#" class="h-8" alt="Logo" />
        <span class="self-center text-2xl font-semibold whitespace-nowrap dark:text-white">Portfolio</span>
    </a>
    <button data-collapse-toggle="navbar-default" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600" aria-controls="navbar-default" aria-expanded="false">
        <span class="sr-only">Open main menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
    </button>
    <!-- Sidebar Hamburger Button (mobile only) -->
    <button data-collapse-toggle="sidebarProfile" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600 ml-2" aria-controls="sidebarProfile" aria-expanded="false">
      <span class="sr-only">Open sidebar</span>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
      </svg>
    </button>
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-white dark:bg-gray-800 md:dark:bg-gray-900 dark:border-gray-700">
        <li>
          <a href="/" class="block py-2 px-3 text-white bg-blue-700 rounded md:bg-transparent md:text-blue-700 md:p-0 dark:text-white md:dark:text-blue-500" aria-current="page">Home</a>
        </li>
        <li>
          <a href="#" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">About</a>
        </li>
        <li>
          <a href="#" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Services</a>
        </li>
        <li>
          <a href="Project" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Project</a>
        </li>
        <li>
          <a href="#" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Contact</a>
        </li>
      </ul>
    </div>
  </div>
  </nav>
  <!-- Sidebar Top Filler to match sidebar background and fill gap -->
  <div class="hidden md:block fixed left-0 top-0 z-40 w-64 h-[4.5rem] bg-white dark:bg-gray-900"></div>
</nav>


  <!-- Fixed Sidebar Profile (toggleable on mobile) -->
  <div id="sidebarProfile" class="flex fixed left-0 h-full w-48 sm:w-56 md:w-64 z-40 bg-white dark:bg-gray-900 rounded-none shadow-md p-3 sm:p-4 md:p-6 flex-col items-center transition-transform duration-300 ease-in-out -translate-x-full md:translate-x-0" style="top:4.5rem; min-width:120px; max-width:16rem;">
    <button class="absolute top-2 right-2 md:hidden text-gray-500 dark:text-gray-300 text-2xl" id="closeSidebar" aria-label="Close sidebar">&times;</button>
    <img id="profileImg" class="w-20 h-20 sm:w-24 sm:h-24 rounded-full mb-2 object-cover" src="https://randomuser.me/api/portraits/women/44.jpg" alt="Profile" />
      <!-- The src will be set by JS if a custom image is saved -->
    <label for="profileUpload" class="mb-4 cursor-pointer text-xs text-blue-600 hover:underline flex flex-col items-center">
      <span>Change Photo</span>
      <input id="profileUpload" type="file" accept="image/*" class="hidden" />
    </label>
    <h2 class="text-lg sm:text-sm font-semibold text-gray-900 dark:text-white">Dela Cruz, John Clarence A.</h2>
    <p class="text-gray-500 dark:text-gray-300 text-xs sm:text-sm">Aspiring Web Developer</p>
    <div class="flex items-center mt-1 mb-4">
      <span class="h-2 w-2 bg-green-500 rounded-full mr-2"></span>
      <span class="text-xs text-green-500">Online</span>
    </div>
    <ul class="w-full space-y-2 mb-8">
      <li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15.232 5.232l3.536 3.536M9 13h6m2 2a9 9 0 11-6.219-8.56'/></svg></span><a href="work" class="text-blue-600 hover:underline">Work</a></li>
      <li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 17v-6a2 2 0 012-2h2a2 2 0 012 2v6'/></svg></span><a href="Tech" class="text-white-600 hover:underline">Tech Stack</a></li>
      <li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 3v18h18'/></svg></span>Account</li>
      <li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M7 7h10M7 11h10M7 15h10'/></svg></span>Documents/Resume</li>
      <li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M17 20h5v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2h5'/></svg></span>Settings </li>
      <li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 4v16m8-8H4'/></svg></span>Coming Soon</li>
    </ul>
  </div>
