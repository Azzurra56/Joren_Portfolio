---
import '../styles/global.css';
import Header from '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Work</title>
  </head>
  <body>
    <Header activePath="/work" />

    <main class="mx-auto max-w-5xl px-6 py-14">
      <h1 class="text-3xl font-bold text-slate-900 md:text-4xl">Work Experience</h1>
      <p class="mt-4 text-slate-600 font-inter">
        This section is ready for your work timeline, internships, and key professional achievements.
      </p>

      <ol class="relative border-s border-default">
        <li class="mb-10 ml-6">
          <div class="absolute w-3 h-3 bg-neutral-quaternary rounded-full mt-1.5 -start-1.5 border border-buffer bg-maroon-500"> </div>
             <time class="lg:text-2xl text-md font-display leading-none text-maroon-600 "> February 2026 - Present</time>
             <h3 class="lg:text-2xl text-sky-600 text-md font-serif text-heading my-2"> DOST STII Intern</h3>
             <p class="mb-4 text-base font-narrow text-body">A Tech Support Intern - Practicing Front-End</p>
        </li>

        <li class="mb-10 ml-6">
           <div class="absolute w-3 h-3 bg-neutral-quaternary rounded-full mt-1.5 -start-1.5 border border-buffer bg-maroon-500"> </div>
              <time class="lg:text-2xl text-md font-display leading-none text-maroon-600 "> January 2025 - February 2026 </time>
              <h3 class="lg:text-2xl text-sky-600 text-md font-serif text-heading my-2"> Capstone Project Manager</h3>
              <p class="mb-4 text-base font-narrow text-body">Fullstack Dev and Project Manager (SMIS)</p>
        </li>

             <li class="mb-10 ml-6">
           <div class="absolute w-3 h-3 bg-neutral-quaternary rounded-full mt-1.5 -start-1.5 border border-buffer bg-maroon-500"> </div>
              <time class="lg:text-2xl text-md font-display leading-none text-maroon-600 "> September 2024 - June 2025 </time>
              <h3 class="lg:text-2xl text-sky-600 text-md font-serif text-heading my-2"> Computer Society Delegates Representative</h3>
              <p class="mb-4 text-base font-narrow text-body">Officer: handles event and signing papers to the administration of PUP-Taguig</p>
        </li>
      </ol>
    </main>
  </body>
</html>
