---
import '../styles/global.css';
import Header from '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Tech Stack</title>
		<style is:global>
			@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,500;9..144,700&display=swap');
			:root {
				--ink: #0f172a;
				--mist: #f8fafc;
				--stone: #e2e8f0;
				--teal: #0f766e;
				--amber: #f59e0b;
			}
			body {
				font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
				color: var(--ink);
			}
			.serif-title {
				font-family: 'Fraunces', serif;
			}
			@keyframes card-reveal {
				0% {
					opacity: 0;
					transform: translateY(16px) scale(0.98);
				}
				100% {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}
			.card-reveal {
				opacity: 0;
				animation: card-reveal 520ms ease-out forwards;
			}
		</style>
	</head>
	<body class="bg-slate-50">
		<Header activePath="/Tech" />

		<div class="relative overflow-hidden">
			<div class="absolute -top-40 -right-32 h-96 w-96 rounded-full bg-amber-200/40 blur-3xl"></div>
			<div class="absolute top-40 -left-32 h-96 w-96 rounded-full bg-teal-200/50 blur-3xl"></div>

			<main class="relative mx-auto max-w-6xl px-6 py-14 md:px-10">
				<section class="mb-12">
					<h1 class="serif-title mt-3 text-4xl font-semibold text-slate-900 md:text-5xl">
						My Current Tech Stack
					</h1>
					<p class="mt-4 max-w-2xl font-mono text-slate-600">
						A curated grid of platforms, frameworks, and runtimes I use to build
						responsive, production-ready web experiences.
					</p>
				</section>

				<section class="mb-10">
					<div class="mb-5 flex items-center justify-between">
						<h2 class="lg:text-3xl text-lg font-semibold text-display-800">Frontend Stack</h2>
						<span class="text-xs font-medium uppercase tracking-widest text-slate-400">UI</span>
					</div>
					<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 40ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-orange-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#F97316" d="M3 2l2 20 7 2 7-2 2-20H3zm15.3 6.3l-.2 2.3-6.1 2.6-6-2.6-.3-2.3 6.3 2.6 6.3-2.6z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">HTML</h3>
									<p class="text-sm text-slate-600">Semantic structure and accessible markup.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 100ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#0EA5E9" d="M4 2l2 20 6 2 6-2 2-20H4zm12.7 6.1l-.2 2.3-5.3 2.2-5.2-2.2-.2-2.3 5.4 2.2 5.5-2.2z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">CSS</h3>
									<p class="text-sm text-slate-600">Custom layouts and responsive styling.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 160ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-purple-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#7C3AED" d="M4 6h16l-2 12-6 2-6-2-2-12zm4 4h8l-.4 2.7-3.6 1.5-3.6-1.5L8 10z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Bootstrap</h3>
									<p class="text-sm text-slate-600">Utility classes and fast layout grids.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 220ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#06B6D4" d="M12 3l7 3-7 3-7-3 7-3zm0 6l6 2.6-6 2.4-6-2.4L12 9zm0 5l5 2.2-5 2-5-2 5-2.2z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Tailwind</h3>
									<p class="text-sm text-slate-600">Design system driven by utility classes.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 280ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-yellow-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#FACC15" d="M5 4h14l-2 16-5 2-5-2-2-16zm7 4l3 6-3 1-3-1 3-6z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">JavaScript</h3>
									<p class="text-sm text-slate-600">Interactive UI behaviors and logic.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 340ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-teal-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#14B8A6" d="M12 3l8 5v8l-8 5-8-5V8l8-5zm0 4.2L7.5 10 12 12.8 16.5 10 12 7.2zm0 6.7L7.5 11.2v4.3L12 18l4.5-2.5v-4.3L12 13.9z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Astro</h3>
									<p class="text-sm text-slate-600">Content-focused sites with minimal JS.</p>
								</div>
							</div>
						</article>
					</div>
				</section>

				<section class="mt-12">
					<div class="mb-5 flex items-center justify-between">
						<h2 class="lg:text-3xl text-lg font-semibold text-slate-800">Backend Stack</h2>
						<span class="text-xs font-medium uppercase tracking-widest text-slate-400">Server</span>
					</div>
					<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 420ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-indigo-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#6366F1" d="M6 4h12v4H6V4zm0 6h12v10H6V10zm4 2v6h4v-6h-4z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">PHP</h3>
									<p class="text-sm text-slate-600">Server-side logic and templating.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 480ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#F43F5E" d="M12 3c4 0 7 2.5 7 6v9l-7 3-7-3V9c0-3.5 3-6 7-6zm0 4.2c-2 0-3.5 1.3-3.5 3v5.5l3.5 1.5 3.5-1.5v-5.5c0-1.7-1.5-3-3.5-3z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Laravel</h3>
									<p class="text-sm text-slate-600">MVC framework for clean APIs.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 540ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#10B981" d="M12 4l7 4v8l-7 4-7-4V8l7-4zm0 3.4L8 9v6l4 2.2L16 15V9l-4-1.6z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">MySQL</h3>
									<p class="text-sm text-slate-600">Reliable relational data storage.</p>
								</div>
							</div>
						</article>
					</div>
				</section>

				<section class="mt-12">
					<div class="mb-5 flex items-center justify-between">
						<h2 class="lg:text-3xl text-lg font-semibold text-slate-800">Game Stack</h2>
						<span class="text-xs font-medium uppercase tracking-widest text-slate-400">Game Creation</span>
					</div>
					<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 420ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-indigo-100">
									<svg viewBox="0 0 128 128" class="h-7 w-7" aria-hidden="true">
										<path d="m63.991 128 51.702-29.855-19.817-11.461-20.26 11.704a1.151 1.151 0 0 1-1.125-.009 1.145 1.145 0 0 1-.568-.975V69.608c0-.819.424-1.56 1.133-1.968L99.13 53.737a1.119 1.119 0 0 1 1.124.009c.352.195.572.564.576.966V78.11l19.83 11.454V29.855L63.99 62.566Zm0 0" />
										<path fill="#4d4d4d" d="m52.397 98.401-20.27-11.718-19.832 11.46L63.991 128V62.566L7.34 29.854V89.56l19.825-11.45V54.714c.009-.401.225-.77.572-.966a1.13 1.13 0 0 1 1.13-.009L52.953 67.64a2.275 2.275 0 0 1 1.133 1.97v27.8a1.156 1.156 0 0 1-.565.98 1.131 1.131 0 0 1-1.124.012" />
										<path fill="gray" d="M68.959 0v22.9L89.22 34.597c.348.203.555.576.555.984 0 .403-.212.772-.555.975L65.137 50.468a2.302 2.302 0 0 1-2.27 0L38.791 36.556a1.122 1.122 0 0 1-.56-.975 1.127 1.127 0 0 1 .56-.984L59.048 22.9V0L7.339 29.855l56.652 32.711 56.665-32.71Zm0 0" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Unity</h3>
									<p class="text-sm text-slate-600">Popular game engine for 2D and 3D development.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 480ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-100">
									<svg viewBox="0 0 128 128" class="h-7 w-7" aria-hidden="true">
										<path fill="#9B4F96" d="M115.4 30.7L67.1 2.9c-.8-.5-1.9-.7-3.1-.7-1.2 0-2.3.3-3.1.7l-48 27.9c-1.7 1-2.9 3.5-2.9 5.4v55.7c0 1.1.2 2.4 1 3.5l106.8-62c-.6-1.2-1.5-2.1-2.4-2.7z" />
										<path fill="#68217A" d="M10.7 95.3c.5.8 1.2 1.5 1.9 1.9l48.2 27.9c.8.5 1.9.7 3.1.7 1.2 0 2.3-.3 3.1-.7l48-27.9c1.7-1 2.9-3.5 2.9-5.4V36.1c0-.9-.1-1.9-.6-2.8l-106.6 62z" />
										<path fill="#fff" d="M85.3 76.1C81.1 83.5 73.1 88.5 64 88.5c-13.5 0-24.5-11-24.5-24.5s11-24.5 24.5-24.5c9.1 0 17.1 5 21.3 12.5l13-7.5c-6.8-11.9-19.6-20-34.3-20-21.8 0-39.5 17.7-39.5 39.5s17.7 39.5 39.5 39.5c14.6 0 27.4-8 34.2-19.8l-12.9-7.6zM97 66.2l.9-4.3h-4.2v-4.7h5.1L100 51h4.9l-1.2 6.1h3.8l1.2-6.1h4.8l-1.2 6.1h2.4v4.7h-3.3l-.9 4.3h4.2v4.7h-5.1l-1.2 6h-4.9l1.2-6h-3.8l-1.2 6h-4.8l1.2-6h-2.4v-4.7H97zm4.8 0h3.8l.9-4.3h-3.8l-.9 4.3z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">C#</h3>
									<p class="text-sm text-slate-600">Programming language for game development.</p>
								</div>
							</div>
						</article>
					</div>
				</section>

					<section class="mt-12">
					<div class="mb-5 flex items-center justify-between">
						<h2 class="lg:text-3xl text-lg font-semibold text-slate-800">Currently Learning</h2>
						<span class="text-xs font-medium uppercase tracking-widest text-slate-400">Tools</span>
						</div>
						<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">

						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-2xl" style="animation-delay: 540ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white">
  <svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
    <path fill="#111827" d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.2-3.37-1.2-.46-1.15-1.11-1.45-1.11-1.45-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.88 1.53 2.32 1.08 2.89.82.09-.64.35-1.08.63-1.33-2.22-.25-4.56-1.12-4.56-4.97 0-1.1.39-2 1.03-2.7-.1-.26-.45-1.29.1-2.68 0 0 .84-.27 2.75 1.03a9.5 9.5 0 0 1 5 0c1.9-1.3 2.74-1.03 2.74-1.03.55 1.39.2 2.42.1 2.68.64.7 1.03 1.6 1.03 2.7 0 3.86-2.34 4.72-4.57 4.97.36.31.68.92.68 1.86v2.76c0 .26.18.58.69.48A10 10 0 0 0 12 2z"/>
  </svg>
</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">GitHub</h3>
									<p class="text-sm text-slate-600">Version control and collaboration platform.</p>
								</div>
								  <div class="w-full bg-neutral-quaternary rounded-full">
    <div class="bg-brand-500 text-xs font-medium text-white text-center p-0.5 leading-none rounded-full h-4 flex items-center justify-center" style="width: 50%"> 50%</div>
                                 </div>
							</div>
						</article>

						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-2xl" style="animation-delay: 540ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white">
 <svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
  <defs>
    <linearGradient id="geminiGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#4285F4" />
      <stop offset="50%" stop-color="#7E57C2" />
      <stop offset="100%" stop-color="#00BCD4" />
    </linearGradient>
  </defs>
  <path
    fill="url(#geminiGrad)"
    d="M12 2.5l1.9 5.1L19 9.5l-5.1 1.9L12 16.5l-1.9-5.1L5 9.5l5.1-1.9L12 2.5z"
  />
  <circle cx="17.6" cy="5.4" r="1.2" fill="#7E57C2" />
  <circle cx="6.4" cy="17.6" r="1.1" fill="#00BCD4" />
</svg>
</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">AI Assistant</h3>
									<p class="text-sm text-slate-600">Intelligent tool for automating tasks and providing insights.</p>
								</div>
							</div>
						</article>
<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-2xl" style="animation-delay: 540ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white">
<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
  <circle cx="12" cy="12" r="1.6" fill="#61DAFB"/>
  <ellipse cx="12" cy="12" rx="9" ry="3.8" fill="none" stroke="#61DAFB" stroke-width="1.4"/>
  <ellipse cx="12" cy="12" rx="9" ry="3.8" fill="none" stroke="#61DAFB" stroke-width="1.4" transform="rotate(60 12 12)"/>
  <ellipse cx="12" cy="12" rx="9" ry="3.8" fill="none" stroke="#61DAFB" stroke-width="1.4" transform="rotate(120 12 12)"/>
                                     </svg>
                                  </div>
						        <div>
									<h3 class="text-xl font-semibold text-slate-900">React</h3>
									<p class="text-sm text-slate-600">Framework for Front-End</p>
								</div>
					              <div class="w-full bg-neutral-quaternary rounded-full">
    <div class="bg-brand-500 text-xs font-medium text-white text-center p-0.5 leading-none rounded-full h-4 flex items-center justify-center" style="width: 0%"></div>
                                 </div>
								   <span class="text-xs font-medium text-slate-700">0%</span>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-2xl" style="animation-delay: 540ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white">
<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
  <path fill="#41B883" d="M2 3h4.2L12 12.6 17.8 3H22l-10 18L2 3z"/>
  <path fill="#35495E" d="M6.2 3H9l3 5 3-5h2.8L12 13 6.2 3z"/>
</svg>
</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Vue.js</h3>
									<p class="text-sm text-slate-600">Framework for JS.</p>
								</div>

								 <div class="w-full bg-neutral-quaternary rounded-full">
    <div class="bg-brand-500 text-xs font-medium text-white text-center p-0.5 leading-none rounded-full h-4 flex items-center justify-center" style="width: 10%"></div>
                            </div>
								   <span class="text-xs font-medium text-slate-700">10%</span>
							</div>
						</article>
						
						</div>
					</section>
			</main>
		</div>

	
						

	</body>
</html>