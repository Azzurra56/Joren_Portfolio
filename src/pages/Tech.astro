---
import '../styles/global.css';
import '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Tech Stack</title>
		<style is:global>
			@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,500;9..144,700&display=swap');
			:root {
				--ink: #0f172a;
				--mist: #f8fafc;
				--stone: #e2e8f0;
				--teal: #0f766e;
				--amber: #f59e0b;
			}
			body {
				font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
				color: var(--ink);
			}
			.serif-title {
				font-family: 'Fraunces', serif;
			}
			@keyframes card-reveal {
				0% {
					opacity: 0;
					transform: translateY(16px) scale(0.98);
				}
				100% {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}
			.card-reveal {
				opacity: 0;
				animation: card-reveal 520ms ease-out forwards;
			}
		</style>
	</head>
	<body class="bg-slate-50">
		<nav class="bg-white border-gray-200 dark:bg-gray-900">
			<div class="max-w-7xl flex flex-wrap items-center justify-between mx-auto p-4">
				<a href="#" class="flex items-center space-x-3 rtl:space-x-reverse">
					<img src="#" class="h-8" alt="Logo" />
					<span class="self-center text-2xl font-semibold whitespace-nowrap dark:text-white">Portfolio</span>
				</a>
				<button data-collapse-toggle="navbar-default" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600" aria-controls="navbar-default" aria-expanded="false">
					<span class="sr-only">Open main menu</span>
					<svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
						<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15" />
					</svg>
				</button>
				<button data-collapse-toggle="sidebarProfile" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600 ml-2" aria-controls="sidebarProfile" aria-expanded="false">
					<span class="sr-only">Open sidebar</span>
					<svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
						<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15" />
					</svg>
				</button>
				<div class="hidden w-full md:block md:w-auto" id="navbar-default">
					<ul class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-white dark:bg-gray-800 md:dark:bg-gray-900 dark:border-gray-700">
						<li>
							<a href="/" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Home</a>
						</li>
						<li>
							<a href="#" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">About</a>
						</li>
						<li>
							<a href="#" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Services</a>
						</li>
						<li>
							<a href="Project" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Project</a>
						</li>
						<li>
							<a href="#" class="block py-2 px-3 text-gray-900 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Contact</a>
						</li>
					</ul>
				</div>
			</div>
		</nav>
		<div class="hidden md:block fixed left-0 top-0 z-40 w-64 h-18 bg-white dark:bg-gray-900"></div>

		<div id="sidebarProfile" class="flex fixed left-0 h-full w-48 sm:w-56 md:w-64 z-40 bg-white dark:bg-gray-900 rounded-none shadow-md p-3 sm:p-4 md:p-6 flex-col items-center transition-transform duration-300 ease-in-out -translate-x-full md:translate-x-0" style="top:4.5rem; min-width:120px; max-width:16rem;">
			<button class="absolute top-2 right-2 md:hidden text-gray-500 dark:text-gray-300 text-2xl" id="closeSidebar" aria-label="Close sidebar">&times;</button>
			<img id="profileImg" class="w-20 h-20 sm:w-24 sm:h-24 rounded-full mb-2 object-cover" src="https://randomuser.me/api/portraits/women/44.jpg" alt="Profile" />
			<label for="profileUpload" class="mb-4 cursor-pointer text-xs text-blue-600 hover:underline flex flex-col items-center">
				<span>Change Photo</span>
				<input id="profileUpload" type="file" accept="image/*" class="hidden" />
			</label>
			<h2 class="text-lg sm:text-sm font-semibold text-gray-900 dark:text-white">Dela Cruz, John Clarence A.</h2>
			<p class="text-gray-500 dark:text-gray-300 text-xs sm:text-sm">Aspiring Web Developer</p>
			<div class="flex items-center mt-1 mb-4">
				<span class="h-2 w-2 bg-green-500 rounded-full mr-2"></span>
				<span class="text-xs text-green-500">Online</span>
			</div>
			<ul class="w-full space-y-2 mb-8">
				<li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15.232 5.232l3.536 3.536M9 13h6m2 2a9 9 0 11-6.219-8.56'/></svg></span><a href="work" class="text-blue-600 hover:underline">Work</a></li>
				<li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 17v-6a2 2 0 012-2h2a2 2 0 012 2v6'/></svg></span><a href="Tech" class="text-white-600 hover:underline">Tech Stack</a></li>
				<li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 3v18h18'/></svg></span>Account</li>
				<li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M7 7h10M7 11h10M7 15h10'/></svg></span>Documents/Resume</li>
				<li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M17 20h5v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2h5'/></svg></span>Settings</li>
				<li class="flex items-center text-gray-700 dark:text-gray-200 hover:text-blue-600 cursor-pointer text-sm sm:text-base"><span class="mr-3"><svg xmlns='http://www.w3.org/2000/svg' class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 4v16m8-8H4'/></svg></span>Coming Soon</li>
			</ul>
		</div>

		<div class="relative overflow-hidden md:ml-64">
			<div class="absolute -top-40 -right-32 h-96 w-96 rounded-full bg-amber-200/40 blur-3xl"></div>
			<div class="absolute top-40 -left-32 h-96 w-96 rounded-full bg-teal-200/50 blur-3xl"></div>

			<main class="relative mx-auto max-w-6xl px-6 py-14 md:px-10">
				<section class="mb-12">
					<h1 class="serif-title mt-3 text-4xl font-semibold text-slate-900 md:text-5xl">
						My Current Tech Stack
					</h1>
					<p class="mt-4 max-w-2xl text-base text-slate-600">
						A curated grid of platforms, frameworks, and runtimes I use to build
						responsive, production-ready web experiences.
					</p>
				</section>

				<section class="mb-10">
					<div class="mb-5 flex items-center justify-between">
						<h2 class="text-lg font-semibold text-slate-800">Frontend Stack</h2>
						<span class="text-xs font-medium uppercase tracking-widest text-slate-400">UI</span>
					</div>
					<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 40ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-orange-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#F97316" d="M3 2l2 20 7 2 7-2 2-20H3zm15.3 6.3l-.2 2.3-6.1 2.6-6-2.6-.3-2.3 6.3 2.6 6.3-2.6z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">HTML</h3>
									<p class="text-sm text-slate-600">Semantic structure and accessible markup.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 100ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#0EA5E9" d="M4 2l2 20 6 2 6-2 2-20H4zm12.7 6.1l-.2 2.3-5.3 2.2-5.2-2.2-.2-2.3 5.4 2.2 5.5-2.2z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">CSS</h3>
									<p class="text-sm text-slate-600">Custom layouts and responsive styling.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 160ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-purple-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#7C3AED" d="M4 6h16l-2 12-6 2-6-2-2-12zm4 4h8l-.4 2.7-3.6 1.5-3.6-1.5L8 10z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Bootstrap</h3>
									<p class="text-sm text-slate-600">Utility classes and fast layout grids.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 220ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#06B6D4" d="M12 3l7 3-7 3-7-3 7-3zm0 6l6 2.6-6 2.4-6-2.4L12 9zm0 5l5 2.2-5 2-5-2 5-2.2z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Tailwind</h3>
									<p class="text-sm text-slate-600">Design system driven by utility classes.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 280ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-yellow-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#FACC15" d="M5 4h14l-2 16-5 2-5-2-2-16zm7 4l3 6-3 1-3-1 3-6z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">JavaScript</h3>
									<p class="text-sm text-slate-600">Interactive UI behaviors and logic.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 340ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-teal-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#14B8A6" d="M12 3l8 5v8l-8 5-8-5V8l8-5zm0 4.2L7.5 10 12 12.8 16.5 10 12 7.2zm0 6.7L7.5 11.2v4.3L12 18l4.5-2.5v-4.3L12 13.9z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Astro</h3>
									<p class="text-sm text-slate-600">Content-focused sites with minimal JS.</p>
								</div>
							</div>
						</article>
					</div>
				</section>

				<section class="mt-12">
					<div class="mb-5 flex items-center justify-between">
						<h2 class="text-lg font-semibold text-slate-800">Backend Stack</h2>
						<span class="text-xs font-medium uppercase tracking-widest text-slate-400">Server</span>
					</div>
					<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 420ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-indigo-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#6366F1" d="M6 4h12v4H6V4zm0 6h12v10H6V10zm4 2v6h4v-6h-4z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">PHP</h3>
									<p class="text-sm text-slate-600">Server-side logic and templating.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 480ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#F43F5E" d="M12 3c4 0 7 2.5 7 6v9l-7 3-7-3V9c0-3.5 3-6 7-6zm0 4.2c-2 0-3.5 1.3-3.5 3v5.5l3.5 1.5 3.5-1.5v-5.5c0-1.7-1.5-3-3.5-3z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">Laravel</h3>
									<p class="text-sm text-slate-600">MVC framework for clean APIs.</p>
								</div>
							</div>
						</article>
						<article class="card-reveal group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-slate-300 hover:shadow-lg" style="animation-delay: 540ms;">
							<div class="flex items-center gap-4">
								<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100">
									<svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
										<path fill="#10B981" d="M12 4l7 4v8l-7 4-7-4V8l7-4zm0 3.4L8 9v6l4 2.2L16 15V9l-4-1.6z" />
									</svg>
								</div>
								<div>
									<h3 class="text-xl font-semibold text-slate-900">MySQL</h3>
									<p class="text-sm text-slate-600">Reliable relational data storage.</p>
								</div>
							</div>
						</article>
					</div>
				</section>
			</main>
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				/** @type {HTMLImageElement | null} */
				const profileImg = document.getElementById('profileImg');
				/** @type {HTMLInputElement | null} */
				const profileUpload = document.getElementById('profileUpload');
				const profileKey = 'profileImg';
				const maxDimension = 512;
				const jpegQuality = 0.85;

				const loadProfileImg = () => {
					try {
						return localStorage.getItem(profileKey);
					} catch {
						return null;
					}
				};

				function saveProfileImg(dataUrl: string) {
					try {
						localStorage.setItem(profileKey, dataUrl);
					} catch (err) {
						console.warn('Profile image could not be saved to localStorage.', err);
					}
				}

				function resizeImage(dataUrl: string, callback: (value: string) => void) {
					const img = new Image();
					img.onload = () => {
						const scale = Math.min(1, maxDimension / Math.max(img.width, img.height));
						const canvas = document.createElement('canvas');
						canvas.width = Math.round(img.width * scale);
						canvas.height = Math.round(img.height * scale);
						const ctx = canvas.getContext('2d');
						if (!ctx) return;
						ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
						const compressed = canvas.toDataURL('image/jpeg', jpegQuality);
						callback(compressed);
					};
					img.src = dataUrl;
					}

				if (profileImg instanceof HTMLImageElement && profileUpload) {
					const savedProfileImg = loadProfileImg();
					if (savedProfileImg) {
						profileImg.src = savedProfileImg;
					}
					profileUpload.addEventListener('change', (e) => {
						const input = e.target;
						if (input && input instanceof HTMLInputElement && input.files && input.files[0]) {
							const file = input.files[0];
							const reader = new FileReader();
							reader.onload = function (ev) {
								if (profileImg && ev.target && typeof ev.target.result === 'string') {
									const handleCompressed = (compressed: string) => {
										profileImg.src = compressed;
										saveProfileImg(compressed);
									};
									resizeImage(ev.target.result, handleCompressed);
								}
							};
							reader.readAsDataURL(file);
						}
					});
				}

				const menuBtn = document.querySelector('[data-collapse-toggle="navbar-default"]');
				const menu = document.getElementById('navbar-default');
				if (menuBtn && menu) {
					menuBtn.addEventListener('click', () => {
						menu.classList.toggle('hidden');
					});
				}

				const sidebar = document.getElementById('sidebarProfile');
				const sidebarBtn = document.querySelector('[data-collapse-toggle="sidebarProfile"]');
				const closeSidebarBtn = document.getElementById('closeSidebar');
				function openSidebar() {
					if (sidebar) sidebar.classList.remove('-translate-x-full');
				}
				function closeSidebar() {
					if (sidebar) sidebar.classList.add('-translate-x-full');
				}
				if (sidebarBtn) {
					sidebarBtn.addEventListener('click', openSidebar);
				}
				if (closeSidebarBtn) {
					closeSidebarBtn.addEventListener('click', closeSidebar);
				}
				document.addEventListener('click', (e) => {
					const target = e.target;
					const clickedSidebarToggle = sidebarBtn && target instanceof Element && sidebarBtn.contains(target);
					if (
						window.innerWidth < 768 &&
						sidebar &&
						target instanceof Element &&
						!sidebar.contains(target) &&
						!clickedSidebarToggle
					) {
						closeSidebar();
					}
				});
			});
		</script>
	</body>
</html>